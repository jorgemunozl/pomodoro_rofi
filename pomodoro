#!/usr/bin/env python3
"""Pomodoro timer — Rofi-powered with polybar integration.

Usage:
    pomodoro                            Launch the rofi UI
    pomodoro status                     Print polybar status line
    pomodoro toggle                     Pause/resume current session
    pomodoro stop                       Stop current session
    pomodoro next                       Skip to the next phase
    pomodoro start [options]            Start a session with CLI arguments
    pomodoro --task <name> --video <file> [options]   (shorthand, same as start)

Options (for start / direct flags):
    --task, -t   <name>                Task name (required)
    --video, -v  <filename>            Video filename or "random" to pick one randomly
    --rhythm, -r <rhythm>              "default" or "work-break" (e.g. "25-5")
    --count, -c  <n>                   Number of pomodoros (default: from rhythm or 1)
    --warmup, -w <secs>                Warm-up seconds (default: from rhythm or 0)
    --audio, -a                        Play audio only (no video, uses mp3)

Examples:
    pomodoro --task "read" --video "study.mp4"
    pomodoro start --task "read" --video "study.mp4"
    pomodoro -t "read" -v "study.mp4" -r "50-10" -c 4 -w 60
    pomodoro --task "write" --video "shinjuku.webm" --rhythm default
    pomodoro --task "read" --video random          # random video + its default rhythm
    pomodoro -t "code" -v random -r "50-10" -c 3   # random video, custom rhythm
    pomodoro --task "read" --video random --audio   # random video, audio only
    pomodoro -t "write" -v "study.mp4" -a          # study.mp4, audio only
"""

import sys
from pathlib import Path


def _find_project_root() -> Path | None:
    """Locate the project root directory containing pomodoro_lib.

    Tries, in order:
      1. Parent of the installed script (works when running from the repo)
      2. $HOME/project/pomodoro_rofi (canonical dev location)
    """
    # 1. Script's own directory
    own = Path(__file__).resolve().parent
    if (own / "pomodoro_lib").is_dir():
        return own

    # 2. Canonical project path
    home = Path.home()
    for candidate in [
        home / "project" / "pomodoro_rofi",
        home / "repos" / "pomodoro_rofi",
        home / "code" / "pomodoro_rofi",
        home / "src" / "pomodoro_rofi",
    ]:
        if (candidate / "pomodoro_lib").is_dir():
            return candidate

    return None


root = _find_project_root()
if root is not None and str(root) not in sys.path:
    sys.path.insert(0, str(root))

from pomodoro_lib.main import main

if __name__ == "__main__":
    main()
